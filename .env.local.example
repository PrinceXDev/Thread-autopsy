RAPIDAPI_KEY=your_key_here
# Optional: RapidAPI twitter scraper host + path.
# Default host is twitter-api45.p.rapidapi.com with /replies.php?tweet_id={tweetId}
# If you subscribe to a different scraper, set these to match its docs.
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com
RAPIDAPI_REPLIES_PATH=/replies.php?tweet_id={tweetId}
